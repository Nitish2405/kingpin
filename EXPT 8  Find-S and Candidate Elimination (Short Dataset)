data = [
    ['High', 'Complete', 'Yes'],
    ['Low', 'Complete', 'No'],
    ['High', 'Incomplete', 'Yes']
]
# FIND-S
h = ['0', '0']
for r in data:
    if r[2] == 'Yes':
        for i in range(2):
            if h[i] == '0':
                h[i] = r[i]
            elif h[i] != r[i]:
                h[i] = '?'
print("Find-S Hypothesis:", h)
# Candidate Elimination
S = h
G = ['?', '?']
print("S =", S)
print("G =", G)
